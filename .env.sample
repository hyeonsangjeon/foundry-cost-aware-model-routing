# Copy to .env and fill in locally. NEVER commit a filled .env (it is .gitignored).
# Placeholder NAMES only here — no real values, endpoints, ids, or keys.

# Live router endpoint
ROUTER_ENDPOINT=

# Model provider endpoint
MODEL_PROVIDER_ENDPOINT=

# Optional gateway base URL
MODEL_GATEWAY_URL=

# Optional cloud context
CLOUD_SUBSCRIPTION_ID=
CLOUD_LOCATION=

# Local experiment threshold
ROUTER_VALUE_THRESHOLD=

# --- Azure AI Foundry Model Router (live measured bridge; all OPTIONAL) ---
# Fill these locally to run `cost-router foundry live` against a real deployment.
# With none set, everything stays offline and the measured flag stays false (default).
# Never commit filled values — this file is a placeholder; .env is gitignored.

# Router deployment endpoint (host of your Azure OpenAI / Foundry resource)
AZURE_AI_FOUNDRY_ENDPOINT=

# The Model Router deployment name (the single-call routing layer)
AZURE_AI_FOUNDRY_MODEL_ROUTER=

# Authentication method: leave blank to auto-detect (API key if set below, else
# Microsoft Entra ID). Use `entra` to force keyless Azure AD auth — the only
# option when your resource has local/key auth disabled (disableLocalAuth true).
# Accepts: entra | aad | key
AZURE_AI_FOUNDRY_AUTH=

# API key for the resource. OPTIONAL under Entra ID auth — leave blank and sign in
# with `az login` (or a managed identity). Only needed for key auth.
AZURE_AI_FOUNDRY_API_KEY=

# Optional AAD token scope for Entra ID auth (defaults to the Cognitive Services
# data-plane scope: https://cognitiveservices.azure.com/.default)
AZURE_AI_FOUNDRY_TOKEN_SCOPE=

# Optional data-plane API version (defaults to a recent stable version)
AZURE_AI_FOUNDRY_API_VERSION=

# Optional: push measured metrics to Foundry / Application Insights observability
AZURE_AI_FOUNDRY_CONNECTION_STRING=

# Optional: path to YOUR tenant's real per-1M-token pricing (for measured spend)
FOUNDRY_PRICING_PATH=

# The `cost-router foundry status|live` commands auto-load this file (.env) before
# reading config; real exported environment variables always win over it.
# Keyless (Entra ID) quick start: leave AZURE_AI_FOUNDRY_API_KEY blank, put `entra`
# in AZURE_AI_FOUNDRY_AUTH above, run `az login` once, and grant your identity the
# "Cognitive Services OpenAI User" role on the resource. No secret ever touches .env.
# Generic Azure OpenAI names are also accepted (first present wins) if you already
# have them set — no need to duplicate:
#   endpoint    → AZURE_OPENAI_ENDPOINT
#   deployment  → AZURE_MODEL_ROUTER_DEPLOYMENT
#   api key     → AZURE_OPENAI_API_KEY
#   api version → AZURE_OPENAI_API_VERSION
#   observ.     → APPLICATIONINSIGHTS_CONNECTION_STRING
#   pricing     → COST_ROUTER_PRICING
